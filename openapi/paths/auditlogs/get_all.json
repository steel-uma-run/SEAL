{
  "get": {
    "tags": ["audit"],
    "summary": "Get all audit logs",
    "operationId": "getAllAuditLogs",
    "security": [
      {
        "bearerAuth": []
      }
    ],
    "responses": {
      "200": {
        "description": "Successful response containing a list of audit logs.",
        "content": {
          "application/json": {
            "schema": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "$ref": "../../components/schemas/AccountApprovedLogDto.json"
                  },
                  {
                    "$ref": "../../components/schemas/AccountBannedLogDto.json"
                  },
                  {
                    "$ref": "../../components/schemas/SubmissionLogDto.json"
                  },
                  {
                    "$ref": "../../components/schemas/GradingLogDto.json"
                  }
                ]
              }
            }
          }
        }
      },
      "4XX": {
        "$ref": "../../responses/ClientErrorResponse.json"
      }
    }
  }
}