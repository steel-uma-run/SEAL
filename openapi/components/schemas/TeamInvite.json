{
  "type": "object",
  "required": ["id", "sent_at", "expires_at", "status", "team_id"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "sent_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["PENDING", "ACCEPTED", "DECLINED"]
    },
    "inviting_team_id": {
      "type": "string",
      "format": "uuid"
    }
  }
}
