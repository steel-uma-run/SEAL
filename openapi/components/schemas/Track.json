      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "mentors": {
      "type": "array",
      "items": {
        "$ref": "./Lecturer.json"
      }
    },
    "judges": {
      "type": "array",
      "items": {
        "$ref": "./Lecturer.json"
      }
    }
  }
