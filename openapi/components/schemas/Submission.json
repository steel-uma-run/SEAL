{
  "type": "object",
  "required": [
    "id",
    "title",
    "description",
    "github_link",
    "youtube_link",
    "slide_link",
    "submitted_at",
    "scores"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "github_link": {
      "type": "string"
    },
    "youtube_link": {
      "type": "string"
    },
    "slide_link": {
      "type": "string"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "scores": {
      "type": "array",
      "items": {
        "$ref": "./Score.json"
      }
    },
    "avgScores": {
      "type": "array",
      "items": {
        "$ref": "./SubmissionAvgScore.json"
      }
    }
  }
}
