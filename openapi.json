{
  "openapi": "3.2.0",
  "info": {
    "title": "SEAL",
    "summary": "SEAL API",
    "license": {
      "name": "GNU Affero General Public License v3.0 only",
      "identifier": "AGPL-3.0-only"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api/v0"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "operationId": "login",
        "description": "Login and obtain a JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully logged in",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponsePayload"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["auth"],
        "operationId": "register",
        "description": "Register a new account",
        "requestBody": {
          "description": "Information to register a new account",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequestPayload"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account registered successfully"
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/events": {
      "post": {
        "tags": ["events"],
        "operationId": "create_event",
        "description": "Create a new event (status starts as DRAFT).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEventRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HackathonEvent"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/teams": {
      "post": {
        "tags": ["teams"],
        "operationId": "create_team",
        "description": "Create a new team",
        "security": [{ "bearerAuthentication": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTeamRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Team created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/teams/{teamId}/approve": {
      "parameters": [
        {
          "name": "teamId",
          "description": "ID of the team",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["teams"],
        "operationId": "approve_team",
        "description": "Approve a pending team",
        "responses": {
          "200": {
            "description": "Team approved successfully"
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/teams/{teamId}/invite/{studentId}": {
      "parameters": [
        {
          "name": "teamId",
          "description": "ID of the team",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "studentId",
          "description": "ID of the invitee",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["teams"],
        "operationId": "invite_to_team",
        "description": "Invite another student to team",
        "responses": {
          "200": {
            "description": "Invite sent successfully"
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/invites": {
      "get": {
        "tags": ["invites"],
        "operationId": "get_all_invites",
        "descriptionId": "Get all invites for the currently authenticated user",
        "responses": {
          "200": {
            "description": "Invites data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TeamInvite"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/invites/{inviteId}/accept": {
      "parameters": [
        {
          "name": "inviteId",
          "description": "ID of the invite",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["invites"],
        "operationId": "accept_invite",
        "description": "Accept a team invite",
        "responses": {
          "200": {
            "description": "Successfully accepted invite"
          }
        }
      }
    },
    "/invites/{inviteId}/decline": {
      "parameters": [
        {
          "name": "inviteId",
          "description": "ID of the invite",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["invites"],
        "operationId": "decline_invite",
        "description": "Decline a team invite",
        "responses": {
          "200": {
            "description": "Successfully declined invite"
          }
        }
      }
    },
    "/seasons": {
      "get": {
        "tags": ["seasons"],
        "operationId": "get_all_seasons",
        "description": "Get all seasons",
        "responses": {
          "200": {
            "description": "Season data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Season"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["seasons"],
        "operationId": "create_season",
        "description": "Create a new season",
        "requestBody": {
          "description": "Data to create a new season",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSeasonRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Season created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Season"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - Only Coordinator can perform this action"
          }
        }
      }
    },
    "/seasons/{seasonId}": {
      "parameters": [
        {
          "name": "seasonId",
          "description": "ID of the season",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["seasons"],
        "operationId": "get_season",
        "description": "Returns info of a specific season",
        "responses": {
          "200": {
            "description": "Season data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Season"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/seasons/{seasonId}/events": {
      "parameters": [
        {
          "name": "seasonId",
          "description": "ID of the season",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["events", "seasons"],
        "operationId": "get_events_in_season",
        "description": "Returns all events in a season",
        "responses": {
          "200": {
            "description": "Events data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HackathonEvent"
                  }
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/seasons/{seasonId}/events/{eventId}": {
      "parameters": [
        {
          "name": "seasonId",
          "description": "ID of the season",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "eventId",
          "description": "ID of the event",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["events", "seasons"],
        "operationId": "get_event",
        "description": "Returns info on a specific event",
        "responses": {
          "200": {
            "description": "Event data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HackathonEvent"
                }
              }
            }
          },
          "422": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/seasons/{seasonId}/events/{eventId}/teams": {
      "parameters": [
        {
          "name": "seasonId",
          "description": "ID of the season",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        },
        {
          "name": "eventId",
          "description": "ID of the event",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["teams", "events", "seasons"],
        "operationId": "get_all_teams_of_events",
        "description": "Returns all teams participating in an event",
        "responses": {
          "200": {
            "description": "Teams data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Team"
                  }
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/tracks/{trackId}": {
      "parameters": [
        {
          "name": "trackId",
          "description": "ID of the track to retrieve",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["tracks"],
        "operationId": "get_track",
        "description": "Get details of a specific track",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Track"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/tracks/{trackId}/assign-mentor": {
      "parameters": [
        {
          "name": "trackId",
          "description": "ID of the track to assign mentor",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["tracks"],
        "operationId": "assign_mentor",
        "description": "Assign a mentor to a specific track (Coordinator only)",
        "security": [{ "bearerAuthentication": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssignMentorRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully assigned mentor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Track"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Lecturer is already a Judge for this track"
          },
          "404": {
            "description": "Track or Lecturer not found"
          }
        }
      }
    },
    "/tracks/{trackId}/assign-team": {
      "parameters": [
        {
          "name": "trackId",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["tracks", "teams"],
        "operationId": "assign_team_to_track",
        "description": "Assign a team to a specific track (Coordinator only)",
        "security": [{ "bearerAuthentication": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssignTeamRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully assigned team to track",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Team"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Event started, team not approved, or track mismatch"
          },
          "404": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/events/{eventId}/tracks": {
      "parameters": [
        {
          "name": "eventId",
          "description": "ID of the event",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": ["tracks", "events"],
        "operationId": "get_all_tracks_of_event",
        "description": "Get a list of all tracks for a specific event",
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Track"
                  }
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      },
      "post": {
        "tags": ["tracks", "events"],
        "operationId": "create_track",
        "description": "Create a new track for an event",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTrackRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Track"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/profile": {
      "get": {
        "tags": ["profile"],
        "operationId": "get_self_profile",
        "description": "Return the profile of the logged-in user",
        "security": [{ "bearerAuthentication": [] }],
        "responses": {
          "200": {
            "description": "The user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    },
    "/account/{accountId}/approve": {
      "parameters": [
        {
          "name": "accountId",
          "description": "ID of the account to approve",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "post": {
        "tags": ["account", "profile"],
        "operationId": "approve_account",
        "description": "Approve a student account",
        "responses": {
          "200": {
            "content": {}
          },
          "4XX": {
            "$ref": "#/components/responses/ClientErrorResponse"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Email": {
        "description": "Email of the user",
        "type": "string",
        "format": "email"
      },
      "CreateTeamRequest": {
        "type": "object",
        "required": ["name", "description", "event_id"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "event_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the Event"
          }
        }
      },
      "CreateEventRequest": {
        "type": "object",
        "required": ["seasonId", "name", "description", "startTime", "endTime"],
        "properties": {
          "seasonId": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "startTime": { "type": "string", "format": "date-time" },
          "endTime": { "type": "string", "format": "date-time" }
        }
      },
      "HackathonEvent": {
        "description": "A hackathon event",
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "status",
          "start_time",
          "end_time",
          "season_id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["DRAFT", "FINALIZED"]
          },
          "start_time": {
            "type": "string",
            "format": "date-time"
          },
          "end_time": {
            "type": "string",
            "format": "date-time"
          },
          "season_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "Track": {
        "description": "A track within an event",
        "type": "object",
        "required": ["id", "name", "description", "event_id"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "event_id": {
            "type": "string",
            "format": "uuid"
          },
          "mentor_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          }
        }
      },
      "CreateTrackRequest": {
        "description": "Payload to create a new track",
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the track"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the track"
          }
        }
      },
      "Season": {
        "description": "A hackathon season. There are 3 of these a year",
        "type": "object",
        "required": ["id", "season", "year"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "semester": {
            "type": "string",
            "enum": ["SPRING", "SUMMER", "FALL"]
          },
          "year": {
            "type": "integer",
            "minimum": 1990,
            "maximum": 9999
          },
          "status": {
            "type": "string",
            "enum": ["DRAFT", "FINALIZED"]
          }
        }
      },
      "CreateSeasonRequest": {
        "type": "object",
        "required": ["semester", "year"],
        "properties": {
          "semester": {
            "type": "string",
            "enum": ["SPRING", "SUMMER", "FALL"]
          },
          "year": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "AssignMentorRequest": {
        "type": "object",
        "required": ["mentor_id"],
        "properties": {
          "mentor_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the Lecturer to be assigned as Mentor"
          }
        }
      },
      "AssignTeamRequest": {
        "type": "object",
        "required": ["team_id"],
        "properties": {
          "team_id": {
            "type": "string",
            "format": "uuid",
            "description": "ID of the Team to assign"
          }
        }
      },
      "User": {
        "description": "A user account",
        "type": "object",
        "required": ["id", "email", "role"],
        "discriminator": {
          "propertyName": "role",
          "mapping": {
            "COORDINATOR": "#/components/schemas/Coordinator",
            "LECTURER": "#/components/schemas/Lecturer",
            "STUDENT": "#/components/schemas/Student"
          }
        },
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": ["COORDINATOR", "STUDENT", "LECTURER"]
          }
        }
      },
      "Coordinator": {
        "description": "Coordinator account",
        "allOf": [
          {
            "$ref": "#/components/schemas/User"
          }
        ]
      },
      "Lecturer": {
        "description": "Lecturer account",
        "allOf": [
          {
            "$ref": "#/components/schemas/User"
          }
        ]
      },
      "Student": {
        "description": "Student account",
        "allOf": [
          {
            "$ref": "#/components/schemas/User"
          },
          {
            "type": "object",
            "required": ["student_id", "is_external", "interested_in_events"],
            "if": {
              "properties": {
                "is_external": { "const": true }
              },
              "required": ["is_external"]
            },
            "then": {
              "required": ["school_name"]
            },
            "properties": {
              "student_id": {
                "type": "string"
              },
              "is_external": {
                "type": "boolean"
              },
              "school_name": {
                "type": "string"
              },
              "team_id": {
                "type": "string",
                "format": "uuid"
              },
              "interested_in_events": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
          }
        ]
      },
      "Team": {
        "type": "object",
        "required": ["id", "name", "status", "members", "leader_id"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "APPROVED"]
          },
          "members": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "leader_id": {
            "type": "string",
            "format": "uuid"
          },
          "track_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "TeamInvite": {
        "type": "object",
        "required": ["id", "sent_at", "expires_at", "status", "team_id"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "sent_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "enum": ["PENDING", "ACCEPTED", "DECLINED"]
          },
          "inviting_team_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },

      "LoginRequestPayload": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "$ref": "#/components/schemas/Email"
          },
          "password": {
            "description": "Password of the user",
            "type": "string"
          }
        }
      },
      "RegisterRequestPayload": {
        "type": "object",
        "required": ["email", "password", "name", "student_id", "is_external"],
        "if": {
          "properties": {
            "is_external": {
              "const": true
            }
          },
          "required": ["is_external"]
        },
        "then": {
          "required": ["school_name"]
        },
        "properties": {
          "email": {
            "$ref": "#/components/schemas/Email"
          },
          "password": {
            "description": "Password of the user",
            "type": "string"
          },
          "name": {
            "description": "Full name of the user",
            "type": "string"
          },
          "student_id": {
            "type": "string"
          },
          "is_external": {
            "description": "Whether the user is an external student",
            "type": "boolean"
          },
          "school_name": {
            "description": "Name of the user's school. MUST be present if isExternal == true",
            "type": "string"
          }
        }
      },
      "LoginResponsePayload": {
        "type": "object",
        "required": ["token", "user"],
        "properties": {
          "token": {
            "description": "The JWT that can be used to authenticate",
            "type": "string"
          },
          "user": {
            "type": "object",
            "required": ["id", "email", "name"],
            "properties": {
              "id": {
                "type": "string",
                "format": "uuid"
              },
              "email": {
                "$ref": "#/components/schemas/Email"
              },
              "name": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": ["STUDENT", "COORDINATOR", "LECTURER"]
              }
            }
          }
        }
      }
    },
    "responses": {
      "ClientErrorResponse": {
        "description": "RFC 7807 Problem Details",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["status", "title", "detail"],
              "properties": {
                "type": {
                  "type": "string"
                },
                "status": {
                  "type": "number"
                },
                "title": {
                  "type": "string"
                },
                "detail": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuthentication": {
        "description": "Bearer token using a JWT",
        "type": "http",
        "scheme": "Bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
